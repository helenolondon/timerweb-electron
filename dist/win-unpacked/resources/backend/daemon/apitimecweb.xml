<service>
	<id>apitimecweb.exe</id>
	<name>Api Time C Web</name>
	<description>This is my Node.js API running silently in the background.</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>E:\lab\timerweb\backend\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>E:\lab\timerweb\backend\server.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>Api Time C Web wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>DESKTOP-ASDC6V3</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>E:\lab\timerweb\backend</workingdirectory>
</service>